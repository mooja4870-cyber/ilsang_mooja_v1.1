# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# Optional: comma-separated key pool for automatic rotation when quota is hit.
# Example: GEMINI_API_KEYS="KEY_A,KEY_B,KEY_C"
GEMINI_API_KEYS=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Naver auto publish (server-side Playwright)
NAVER_LOGIN_MODE="hybrid"
NAVER_USERNAME=""
NAVER_PASSWORD=""
NAVER_BLOG_ID=""

# Browser runtime safety
# - In production/Linux without DISPLAY, headless is auto-forced to true.
# - You can still pin this explicitly when needed.
BROWSER_HEADLESS="true"
NAVER_TRACE_ENABLED="false"
